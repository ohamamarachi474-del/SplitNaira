PORT=3001
# Development default. Production MUST set this to explicit origins (comma-separated).
# Wildcard (*) is rejected in production. Example: https://app.splitnaira.com,https://splitnaira.com
CORS_ORIGIN=http://localhost:3000

LOG_LEVEL=info
# Set to "json" in production for structured/searchable logs (e.g. Render log drain).
# Set to "pretty" (default) for human-readable coloured output in development.
LOG_FORMAT=pretty

DATABASE_URL=postgresql://user:password@localhost:5432/splitnaira
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CONTRACT_ID=
SIMULATOR_ACCOUNT=

# Error monitoring (optional — leave blank to disable Sentry)
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_SCRUB_WALLET_ADDRESSES=true

# Response validation (optional)
# Set to "true" to hard-fail (500) on response schema mismatch. Defaults to true in production.
# STRICT_RESPONSE_VALIDATION=true

# Performance tuning (optional)
# READ_CACHE_TTL_MS=30000
# READ_CACHE_MAX_ENTRIES=500
# DATABASE_POOL_MAX=10
// SplitNaira is in active development. This repo currently contains:

// - `contracts/` Soroban smart contract and tests
// - `frontend/` Next.js + Tailwind scaffold
// - `backend/` Express API scaffold
// - `demo/` Static HTML flow prototype
